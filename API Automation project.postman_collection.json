      "name": "Router",
      "item": [
        {
          "name": "Router",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "let action = pm.iterationData.get(\"action\");\r",
                  "\r",
                  "switch (action) {\r",
                  "\r",
                  "    case \"login\":\r",
                  "        pm.execution.setNextRequest(\"login\")\r",
                  "        break;\r",
                  "\r",
                  "    case \"register\":\r",
                  "         pm.execution.setNextRequest(\"register\")\r",
                  "        break;\r",
                  "\r",
                  "    case \"update\":\r",
                  "         pm.execution.setNextRequest(\"update user\")\r",
                  "        break;\r",
                  "\r",
                  "    case \"delete\":\r",
                  "        pm.execution.setNextRequest(\"delete\")\r",
                  "        break;\r",
                  "\r",
                  "    default:\r",
                  "          pm.execution.setNextRequest(null)\r",
                  "}"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "https://postman-echo.com/get",
              "protocol": "https",
              "host": [
                "postman-echo",
                "com"
              ],
              "path": [
                "get"
              ]
            }
          },
          "response": []
        }
      ]
