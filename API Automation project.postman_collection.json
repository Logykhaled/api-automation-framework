          "name": "register",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "let action = pm.iterationData.get(\"action\");\r",
                  "let expectedStatus = parseInt(pm.iterationData.get(\"expected_status\"));\r",
                  "\r",
                  "let jsonData = {};\r",
                  "try {\r",
                  "    jsonData = pm.response.json();\r",
                  "} catch(e){}\r",
                  "\r",
                  "// 🛑 Guard مهم\r",
                  "if (!action || isNaN(expectedStatus)) {\r",
                  "    console.log(\"CSV issue:\", pm.iterationData.toObject());\r",
                  "    return;\r",
                  "}\r",
                  "\r",
                  "if (action === \"register\") {\r",
                  "\r",
                  "    if (expectedStatus === 200) {\r",
                  "\r",
                  "        pm.test(\"ID exists\", function () {\r",
                  "            pm.expect(jsonData.id).to.exist;\r",
                  "        });\r",
                  "\r",
                  "    } else {\r",
                  "\r",
                  "        pm.test(\"Register error exists\", function () {\r",
                  "            pm.expect(jsonData).to.have.property(\"error\");\r",
                  "        });\r",
                  "    }\r",
                  "}\r",
                  "\r",
                  "// ✅ الصح\r",
                  "pm.execution.setNextRequest(null)\r",
                  "console.log(\"EXPECTED STATUS:\", pm.iterationData.get(\"expected_status\"));"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            },
